#!/bin/zsh
# Claude Code Token 监控脚本

PROJECTS_DIR="$HOME/.claude/projects"
STATS_DIR="$HOME/.claude/token-stats"
CONFIG_FILE="$STATS_DIR/config/prices.json"
mkdir -p "$STATS_DIR/sessions" "$STATS_DIR/daily" "$STATS_DIR/archives" "$STATS_DIR/config"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
GRAY='\033[0;90m'
NC='\033[0m'

# 加载价格配置
load_price_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        echo "$(cat "$CONFIG_FILE")"
    else
        echo '{"default": {"input": 0.8, "output": 0.8}, "models": {}}'
    fi
}

# 从 LiteLLM 拉取最新模型价格
fetch_litellm_prices() {
    local LITELLM_URL="https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json"
    local TMP_FILE=$(mktemp)

    echo -e "${CYAN}正在从 LiteLLM 获取最新价格...${NC}" >&2

    if ! curl -sf --max-time 15 "$LITELLM_URL" -o "$TMP_FILE" 2>/dev/null; then
        echo -e "${YELLOW}警告: 价格获取失败，网络不可用或超时，使用本地价格配置${NC}" >&2
        rm -f "$TMP_FILE"
        return 1
    fi

    # 过滤并转换格式：per-token -> per-million，保留所有 chat/completion 类模型
    local NEW_MODELS
    NEW_MODELS=$(jq '
        to_entries
        | map(select(
            (.value.mode == "chat" or .value.mode == "completion")
            and (.value.input_cost_per_token != null)
            and (.value.output_cost_per_token != null)
          ))
        | map({
            key: .key,
            value: {
              input:  (.value.input_cost_per_token  * 1000000 | (. * 10000 | round) / 10000),
              output: (.value.output_cost_per_token * 1000000 | (. * 10000 | round) / 10000),
              provider: (.value.litellm_provider // "unknown"),
              cache_read: (if .value.cache_read_input_token_cost != null
                           then (.value.cache_read_input_token_cost * 1000000 | (. * 10000 | round) / 10000)
                           else null end)
            }
          })
        | from_entries
    ' "$TMP_FILE" 2>/dev/null)

    if [[ -z "$NEW_MODELS" || "$NEW_MODELS" == "null" ]]; then
        echo -e "${RED}错误: 价格数据解析失败${NC}" >&2
        rm -f "$TMP_FILE"
        return 1
    fi

    # 读取现有配置，保留 LiteLLM 不收录的自定义模型（如 kimi 等）
    local EXISTING_CONFIG
    EXISTING_CONFIG=$(load_price_config)
    local EXISTING_MODELS
    EXISTING_MODELS=$(echo "$EXISTING_CONFIG" | jq '.models // {}')
    local DEFAULT_PRICE
    DEFAULT_PRICE=$(echo "$EXISTING_CONFIG" | jq '.default // {"input": 0.8, "output": 0.8}')
    local CACHE_DISCOUNT
    CACHE_DISCOUNT=$(echo "$EXISTING_CONFIG" | jq '.cache_discount // {"read_multiplier": 0.1}')

    # 合并：LiteLLM 覆盖同名模型，自定义模型（LiteLLM 不含）保留
    local MERGED_MODELS
    MERGED_MODELS=$(jq -n \
        --argjson litellm "$NEW_MODELS" \
        --argjson existing "$EXISTING_MODELS" \
        '($existing | to_entries | map(select(.key as $k | $litellm | has($k) | not)) | from_entries) + $litellm'
    )

    # 保留现有 aliases
    local EXISTING_ALIASES
    EXISTING_ALIASES=$(echo "$EXISTING_CONFIG" | jq '.aliases // {}')

    local MODEL_COUNT
    MODEL_COUNT=$(echo "$NEW_MODELS" | jq 'keys | length')

    jq -n \
        --argjson models "$MERGED_MODELS" \
        --argjson aliases "$EXISTING_ALIASES" \
        --argjson default_p "$DEFAULT_PRICE" \
        --argjson cache_d "$CACHE_DISCOUNT" \
        --arg fetched_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '{
            models: $models,
            aliases: $aliases,
            default: $default_p,
            cache_discount: $cache_d,
            _meta: { fetched_at: $fetched_at, source: "litellm" }
        }' > "$CONFIG_FILE"

    rm -f "$TMP_FILE"
    echo -e "${GREEN}价格已更新：从 LiteLLM 获取到 ${MODEL_COUNT} 个模型${NC}" >&2
    return 0
}

# 检查价格数据新鲜度，必要时自动更新
check_price_freshness() {
    # prices.json 不存在 → 首次运行，同步拉取
    if [[ ! -f "$CONFIG_FILE" ]]; then
        fetch_litellm_prices
        return
    fi

    # 读取上次拉取时间
    local fetched_at
    fetched_at=$(jq -r '._meta.fetched_at // empty' "$CONFIG_FILE" 2>/dev/null)
    [[ -z "$fetched_at" ]] && return  # 旧格式文件，跳过

    # 计算天数（兼容 macOS / Linux）
    local fetch_epoch now_epoch age_days
    if [[ "$OSTYPE" == "darwin"* ]]; then
        fetch_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$fetched_at" "+%s" 2>/dev/null || echo 0)
    else
        fetch_epoch=$(date -d "$fetched_at" "+%s" 2>/dev/null || echo 0)
    fi
    now_epoch=$(date +%s)
    age_days=$(( (now_epoch - fetch_epoch) / 86400 ))

    if (( age_days >= 7 )); then
        echo -e "${GRAY}价格数据已 ${age_days} 天未更新，后台静默更新中...${NC}" >&2
        fetch_litellm_prices &>/dev/null &
        disown $! 2>/dev/null || true
    fi
}

# 获取模型价格 (从配置文件)
get_model_price() {
    local model="$1"
    local type="$2"  # input 或 output
    local config=$(load_price_config)

    # 解析别名：先检查 aliases 字段
    local alias_target
    alias_target=$(echo "$config" | jq -r ".aliases[\"$model\"] // empty" 2>/dev/null)
    [[ -n "$alias_target" ]] && model="$alias_target"

    # 尝试精确匹配
    local price=$(echo "$config" | jq -r ".models[\"$model\"].$type // empty" 2>/dev/null)

    # 如果未找到，尝试前缀匹配
    if [[ -z "$price" ]]; then
        # 尝试匹配模型名称前缀
        price=$(echo "$config" | jq -r ".models | to_entries | map(select(.key | startswith(\"$model\"))) | first | .value.$type // empty" 2>/dev/null)
    fi

    # 如果仍未找到，尝试从模型名称推断
    if [[ -z "$price" ]]; then
        case "$model" in
            *opus*|*Opus*)     [[ "$type" == "input" ]] && echo "15.0" || echo "75.0" ;;
            *sonnet*|*Sonnet*) [[ "$type" == "input" ]] && echo "3.0" || echo "15.0" ;;
            *haiku*|*Haiku*)   [[ "$type" == "input" ]] && echo "0.8" || echo "4.0" ;;
            *kimi*|*Kimi*)     echo "0.8" ;;
            *gpt-4o*)          [[ "$type" == "input" ]] && echo "2.5" || echo "10.0" ;;
            *gpt-4*)           [[ "$type" == "input" ]] && echo "30.0" || echo "60.0" ;;
            *gpt-3.5*)         [[ "$type" == "input" ]] && echo "0.5" || echo "1.5" ;;
            *deepseek*)        [[ "$type" == "input" ]] && echo "0.27" || echo "1.1" ;;
            *gemini*flash*)    [[ "$type" == "input" ]] && echo "0.075" || echo "0.3" ;;
            *gemini*pro*)      [[ "$type" == "input" ]] && echo "1.25" || echo "5.0" ;;
            *qwen*max*)        [[ "$type" == "input" ]] && echo "0.5" || echo "1.0" ;;
            *qwen*turbo*)      [[ "$type" == "input" ]] && echo "0.05" || echo "0.1" ;;
            *qwen*)            [[ "$type" == "input" ]] && echo "0.2" || echo "0.4" ;;
            *)                 echo "$config" | jq -r ".default.$type // 0.8" ;;
        esac
    else
        echo "$price"
    fi
}

# 计算费用
calculate_cost() {
    local model="$1"
    local input_tokens="$2"
    local output_tokens="$3"

    local input_price=$(get_model_price "$model" "input")
    local output_price=$(get_model_price "$model" "output")

    # 使用 bc 进行精确计算
    local cost=$(echo "scale=6; ($input_tokens * $input_price + $output_tokens * $output_price) / 1000000" | bc 2>/dev/null || echo "0")
    printf "%.4f" "$cost"
}

process_file() {
    local file="$1"
    local session_id=$(basename "$file" .jsonl)
    local stat_file="$STATS_DIR/sessions/${session_id}.csv"
    local count_file="$STATS_DIR/sessions/${session_id}.count"

    [[ ! -f "$file" ]] && return 1
    local total_lines=$(wc -l < "$file" 2>/dev/null || echo 0)
    [[ "$total_lines" -eq 0 ]] && return 1

    local start_line=1
    [[ -f "$count_file" ]] && start_line=$(( $(cat "$count_file" 2>/dev/null) + 1 ))
    [[ "$start_line" -gt "$total_lines" ]] && return 0

    local project_path=$(dirname "$file" | sed "s|$PROJECTS_DIR/||" | sed 's|/.*||')

    # 创建临时目录按日期存储新增记录
    local tmp_dir=$(mktemp -d)

    # 按日期分组输出，使用消息实际时间而非文件修改时间
    tail -n +"$start_line" "$file" 2>/dev/null | grep '"type":"assistant"' | \
    jq -r --arg project "$project_path" --arg sid "$session_id" --arg tmpdir "$tmp_dir" '
        select(.message.usage) |
        (.timestamp // .message.timestamp // now | split("T")[0]) as $date |
        ($date | split("-")[0:2] | join("-")) as $month |
        # 过滤无效模型名
        select(.message.model // "unknown" | test("^(synthetic|model|)$"; "i") | not) |
        # 输出格式: date|month|session|project|model|input|output|cache_create|cache_read
        "\($date)|\($month)|\($sid)|\($project)|\(.message.model // "unknown")|\(.message.usage.input_tokens // 0)|\(.message.usage.output_tokens // 0)|\(.message.usage.cache_creation_input_tokens // 0)|\(.message.usage.cache_read_input_tokens // 0)"
    ' 2>/dev/null | tee -a "$stat_file" | awk -F'|' -v tmpdir="$tmp_dir" '{
        d = $1
        m = $2
        # 过滤无效模型名
        if ($5 != "" && $5 != "model" && $5 !~ /^<.*>$/) {
            # 按月聚合存储，但保留日期在第一列
            outfile = tmpdir "/" m ".txt"
            # 存储格式: date|session|project|model|input|output|cache_create|cache_read
            printf "%s|%s|%s|%s|%d|%d|%d|%d\n", $1,$3,$4,$5,$6,$7,$8,$9 >> outfile
        }
    }'

    # 将新增记录追加到对应月份的 monthly 文件
    for tmp_file in "$tmp_dir"/*.txt; do
        [[ -f "$tmp_file" ]] || continue
        local month_str=$(basename "$tmp_file" .txt)
        local monthly_file="$STATS_DIR/monthly/${month_str}.csv"
        mkdir -p "$STATS_DIR/monthly"
        cat "$tmp_file" >> "$monthly_file"
        sort -u "$monthly_file" > "$monthly_file.new" && mv "$monthly_file.new" "$monthly_file"
    done

    rm -rf "$tmp_dir"
    echo "$total_lines" > "$count_file"

    echo $((total_lines - start_line + 1))
}

init_process() {
    echo -e "${YELLOW}初始化：扫描现有会话文件...${NC}"
    local count=0
    for file in "$PROJECTS_DIR"/*/*.jsonl; do
        [[ -f "$file" ]] || continue
        local processed=$(process_file "$file")
        [[ -n "$processed" && "$processed" -gt 0 ]] && ((count++)) && echo -e "  ${GREEN}✓${NC} $(basename "$file" .jsonl | cut -c1-30)...: +$processed"
    done
    echo -e "${GREEN}初始化完成，共处理 $count 个会话${NC}"
}

rescan_all() {
    echo -e "${YELLOW}全量重新统计：清除缓存并重新扫描所有会话...${NC}"
    echo ""

    # 删除所有 count 文件，强制重新处理
    local count_files=$(find "$STATS_DIR/sessions" -name "*.count" 2>/dev/null | wc -l)
    if [[ $count_files -gt 0 ]]; then
        rm -f "$STATS_DIR/sessions"/*.count
        echo -e "  ${GREEN}✓${NC} 已清除 $count_files 个缓存文件"
    fi

    # 备份并清空 monthly 文件
    if [[ -d "$STATS_DIR/monthly" ]]; then
        local backup_dir="$STATS_DIR/backups/$(date +%Y%m%d_%H%M%S)"
        mkdir -p "$backup_dir"
        cp "$STATS_DIR/monthly"/*.csv "$backup_dir/" 2>/dev/null
        rm -f "$STATS_DIR/monthly"/*.csv
        echo -e "  ${GREEN}✓${NC} 已备份并清空历史统计 (备份: $backup_dir)"
    fi

    echo ""
    echo -e "${CYAN}开始重新统计所有会话...${NC}"
    echo ""

    local count=0
    local total_sessions=0
    for file in "$PROJECTS_DIR"/*/*.jsonl; do
        [[ -f "$file" ]] || continue
        ((total_sessions++))
        local session_name=$(basename "$file" .jsonl | cut -c1-40)
        local processed=$(process_file "$file")
        if [[ -n "$processed" && "$processed" -gt 0 ]]; then
            ((count++))
            echo -e "  ${GREEN}✓${NC} $session_name: +$processed 条记录"
        fi
    done

    echo ""
    echo -e "${GREEN}全量统计完成！${NC}"
    echo -e "  总会话数: $total_sessions"
    echo -e "  处理会话: $count"
    echo ""
    echo -e "${CYAN}今日统计:${NC}"
    show_today
}

# 获取指定日期的数据（从月文件中筛选）
get_date_data() {
    local target_date="$1"
    local month=$(echo "$target_date" | cut -d'-' -f1-2)
    local monthly_file="$STATS_DIR/monthly/${month}.csv"

    if [[ ! -f "$monthly_file" ]]; then
        return 1
    fi

    # 从月文件中筛选出指定日期的数据（去掉第一列的日期）
    grep "^${target_date}|" "$monthly_file" 2>/dev/null | cut -d'|' -f2-
}

show_today() { show_date_models "$(date +%Y-%m-%d)"; }

show_date_models() {
    local target_date="${1:-$(date +%Y-%m-%d)}"
    echo ""
    echo "╔════════════════════════════════════════════════════════════════════════════════════╗"
    printf "║         Claude Code Token 统计 - %-45s ║\n" "$target_date"
    echo "╚════════════════════════════════════════════════════════════════════════════════════╝"
    echo ""

    local data=$(get_date_data "$target_date")
    if [[ -z "$data" ]]; then
        echo -e "${YELLOW}该日期暂无数据${NC}"
        return 1
    fi

    printf "${CYAN}%-25s %12s %12s %12s %12s %12s %12s${NC}\n" "Model" "Input" "Output" "CacheCreate" "CacheRead" "Total" "Cost(USD)"
    printf "%s\n" "────────────────────────────────────────────────────────────────────────────────────"

    echo "$data" | awk -F'|' '{
        m=$3; inp[m]+=$4; out[m]+=$5; cc[m]+=$6; cr[m]+=$7; models[m]=1
    } END {
        for (m in models) { total=inp[m]+out[m]; cost=(inp[m]*0.8+out[m]*0.8)/1000000;
            printf "%-25s %12d %12d %12d %12d %12d %12.4f\n", substr(m,1,25), inp[m], out[m], cc[m], cr[m], total, cost
            ti+=inp[m]; to+=out[m]; tcc+=cc[m]; tcr+=cr[m]
        }
        tt=ti+to; tc=(ti*0.8+to*0.8)/1000000
        print "────────────────────────────────────────────────────────────────────────────────────"
        printf "%-25s %12d %12d %12d %12d %12d %12.4f\n", "TOTAL", ti, to, tcc, tcr, tt, tc
    }'
    echo ""
}

show_by_project() {
    local target_date="${1:-$(date +%Y-%m-%d)}"
    local data=$(get_date_data "$target_date")
    [[ -z "$data" ]] && echo -e "${YELLOW}暂无数据${NC}" && return 1

    echo ""
    echo "╔════════════════════════════════════════════════════════════════════════════════════╗"
    printf "║         按项目统计 - %-45s ║\n" "$target_date"
    echo "╚════════════════════════════════════════════════════════════════════════════════════╝"
    echo ""
    printf "${CYAN}%-50s %8s %12s %12s %12s${NC}\n" "Project" "Sessions" "Input" "Output" "Cost(USD)"
    printf "%s\n" "────────────────────────────────────────────────────────────────────────────────────"

    echo "$data" | awk -F'|' '{
        p=$2; inp[p]+=$4; out[p]+=$5
        if (!seen[p","$1]++) sess_count[p]++
    } END {
        for (p in inp) { cost=(inp[p]*0.8+out[p]*0.8)/1000000; sc=sess_count[p]+0;
            printf "%-50s %8d %12d %12d %12.4f\n", substr(p,1,50), sc, inp[p], out[p], cost
        }
    }'
    echo ""
}

show_sessions() {
    local target_date="${1:-$(date +%Y-%m-%d)}"
    local data=$(get_date_data "$target_date")

    echo ""
    echo "╔════════════════════════════════════════════════════════════════════════════════════╗"
    printf "║         会话明细 - %-45s ║\n" "$target_date"
    echo "╚════════════════════════════════════════════════════════════════════════════════════╝"
    echo ""

    if [[ -z "$data" ]]; then
        echo -e "${YELLOW}该日期暂无数据${NC}"
        return 1
    fi

    printf "${CYAN}%-36s %-30s %12s %12s %12s %12s${NC}\n" \
        "Session ID" "Project" "Input" "Output" "Cache" "Total"
    printf "%s\n" "────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────"

    echo "$data" | awk -F'|' '{
        sid=$1; proj=$2; inp[sid]+=$4; out[sid]+=$5; cache[sid]+=$7; proj_name[sid]=proj
    } END {
        for (s in inp) {
            total = inp[s] + out[s]
            printf "%-36s %-30s %12d %12d %12d %12d\n", \
                substr(s,1,36), substr(proj_name[s],1,30), inp[s], out[s], cache[s], total
            ti += inp[s]; to += out[s]; tc += cache[s]
        }
        print "────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────"
        printf "%-67s %12d %12d %12d %12d\n", "TOTAL", ti, to, tc, ti+to
    }'

    echo ""
}

show_summary() {
    echo ""
    echo "╔════════════════════════════════════════════════════════════════════════════════════╗"
    echo "║                     Claude Code Token 历史汇总                                     ║"
    echo "╚════════════════════════════════════════════════════════════════════════════════════╝"
    echo ""
    printf "${CYAN}%-12s %8s %14s %14s %14s %12s${NC}\n" "Date" "Sessions" "Input" "Output" "Total" "Cost(USD)"
    printf "%s\n" "────────────────────────────────────────────────────────────────────────────────────"

    # 从所有月文件中按日期汇总
    for mf in "$STATS_DIR"/monthly/*.csv; do
        [[ -f "$mf" ]] || continue
        # 按日期分组统计
        awk -F'|' '{
            d=$1; sess[d][$2]=1; inp[d]+=$5; out[d]+=$6
        } END {
            for (d in inp) {
                cost=(inp[d]*0.8+out[d]*0.8)/1000000;
                printf "%-12s %8d %14d %14d %14d %12.4f\n", d, length(sess[d]), inp[d], out[d], inp[d]+out[d], cost
            }
        }' "$mf"
    done | sort
    echo ""
}

export_csv() {
    local target_date="${1:-$(date +%Y-%m-%d)}"
    local month=$(echo "$target_date" | cut -d'-' -f1-2)
    local monthly_file="$STATS_DIR/monthly/${month}.csv"
    local output_file="$STATS_DIR/cc_report_${target_date}.csv"

    echo "date,session_id,project,model,input_tokens,output_tokens,cache_create,cache_read,total,cost_usd" > "$output_file"

    if [[ -f "$monthly_file" ]]; then
        # 从月文件中筛选指定日期的数据，并转换为 CSV 格式
        grep "^${target_date}|" "$monthly_file" 2>/dev/null | awk -F'|' '{
            # 格式: date|session|project|model|input|output|cache_create|cache_read
            t=$5+$6; c=($5*0.8+$6*0.8)/1000000;
            printf "%s,%s,%s,%s,%d,%d,%d,%d,%d,%.6f\n", $1, $2, $3, $4, $5, $6, $7, $8, t, c
        }' >> "$output_file"
    fi

    echo -e "${GREEN}报告已导出: $output_file ($(wc -l < "$output_file") 行)${NC}"
}

# 查看和编辑配置
show_config() {
    echo ""
    echo "╔════════════════════════════════════════════════════════════════════════════════════╗"
    echo "║                        模型价格配置                                                ║"
    echo "╚════════════════════════════════════════════════════════════════════════════════════╝"
    echo ""

    if [[ -f "$CONFIG_FILE" ]]; then
        echo -e "${CYAN}配置文件路径:${NC} $CONFIG_FILE"
        echo ""

        # 显示价格数据来源和时效
        local fetched_at source_tag
        fetched_at=$(jq -r '._meta.fetched_at // empty' "$CONFIG_FILE" 2>/dev/null)
        if [[ -n "$fetched_at" ]]; then
            if [[ "$OSTYPE" == "darwin"* ]]; then
                local fetch_epoch now_epoch age_days
                fetch_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$fetched_at" "+%s" 2>/dev/null || echo 0)
                now_epoch=$(date +%s)
                age_days=$(( (now_epoch - fetch_epoch) / 86400 ))
            else
                age_days=$(( ( $(date +%s) - $(date -d "$fetched_at" +%s 2>/dev/null || echo 0) ) / 86400 ))
            fi
            local freshness_color="${GREEN}"
            (( age_days >= 7 )) && freshness_color="${YELLOW}"
            (( age_days >= 30 )) && freshness_color="${RED}"
            echo -e "${CYAN}价格来源:${NC} LiteLLM  ${freshness_color}(上次更新: ${fetched_at}，${age_days} 天前)${NC}"
            echo -e "运行 ${YELLOW}cc-token-monitor price-update${NC} 手动更新"
        else
            echo -e "${CYAN}价格来源:${NC} 本地配置 (运行 ${YELLOW}price-update${NC} 从 LiteLLM 更新)"
        fi
        echo ""

        # 显示默认价格
        local default_input=$(jq -r '.default.input // 0.8' "$CONFIG_FILE")
        local default_output=$(jq -r '.default.output // 0.8' "$CONFIG_FILE")
        echo -e "${YELLOW}默认价格:${NC} Input \$${default_input}/M, Output \$${default_output}/M"
        echo ""

        # 显示已配置的模型价格
        local model_count
        model_count=$(jq '.models | keys | length' "$CONFIG_FILE" 2>/dev/null || echo 0)
        echo -e "${CYAN}已配置模型价格 (${model_count} 个, USD per 1M tokens):${NC}"
        echo ""
        jq -r '.models | to_entries | sort_by(.value.provider, .key)[] | "  \(.value.provider): \(.key)\n      Input: $\(.value.input), Output: $\(.value.output)"' "$CONFIG_FILE" 2>/dev/null || echo "  配置加载失败"

        echo ""
        echo "提示:"
        echo "  1. 手动更新价格: cc-token-monitor price-update"
        echo "  2. 编辑配置文件: open $CONFIG_FILE"
        echo "  3. 价格单位: USD per 1M tokens"
        echo ""
    else
        echo -e "${YELLOW}配置文件不存在，将从 LiteLLM 自动获取价格...${NC}"
        fetch_litellm_prices
    fi
}

# 查询指定模型的价格
query_price() {
    local model="$1"

    if [[ -z "$model" ]]; then
        echo "用法: cc-token-monitor price <模型名称>"
        echo ""
        echo "示例:"
        echo "  cc-token-monitor price kimi-for-coding"
        echo "  cc-token-monitor price gpt-4o"
        echo "  cc-token-monitor price claude-sonnet"
        return 1
    fi

    local input_price=$(get_model_price "$model" "input")
    local output_price=$(get_model_price "$model" "output")

    # 检查是否有别名，给出提示
    local alias_target
    alias_target=$(jq -r ".aliases[\"$model\"] // empty" "$CONFIG_FILE" 2>/dev/null)

    echo ""
    if [[ -n "$alias_target" ]]; then
        echo -e "${CYAN}模型: $model${NC} ${GRAY}→ ${alias_target}${NC}"
    else
        echo -e "${CYAN}模型: $model${NC}"
    fi
    echo "  Input:  \$${input_price}/M tokens"
    echo "  Output: \$${output_price}/M tokens"
    echo ""
    echo "费用示例 (100万 tokens):"
    echo "  纯输入:  \$${input_price}"
    echo "  纯输出:  \$${output_price}"
    printf "  50/50:   \$%.2f\n" $(echo "scale=2; ($input_price + $output_price) / 2" | bc)

    # 显示价格来源时间
    if [[ -f "$CONFIG_FILE" ]]; then
        local fetched_at
        fetched_at=$(jq -r '._meta.fetched_at // empty' "$CONFIG_FILE" 2>/dev/null)
        [[ -n "$fetched_at" ]] && echo -e "\n${GRAY}价格来源: LiteLLM (${fetched_at})${NC}"
    fi
    echo ""
}

# 管理模型别名
cmd_price_alias() {
    local subcmd="${1:-list}"

    case "$subcmd" in
        add)
            local alias_name="$2"
            local target_model="$3"
            if [[ -z "$alias_name" || -z "$target_model" ]]; then
                echo "用法: cc-token-monitor price-alias add <别名> <目标模型>"
                echo "示例: cc-token-monitor price-alias add kimi-for-coding kimi-k2.5"
                return 1
            fi
            # 检查目标模型是否存在
            local target_exists
            target_exists=$(jq -r ".models[\"$target_model\"] // empty" "$CONFIG_FILE" 2>/dev/null)
            if [[ -z "$target_exists" ]]; then
                echo -e "${YELLOW}提示: 目标模型 '$target_model' 在价格库中不存在，仍将添加映射${NC}"
            fi
            # 写入 aliases
            local tmp=$(mktemp)
            jq --arg alias "$alias_name" --arg target "$target_model" \
                '.aliases[$alias] = $target' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
            echo -e "${GREEN}已添加别名: ${CYAN}$alias_name${NC} → ${CYAN}$target_model${NC}"
            ;;
        remove|rm|del)
            local alias_name="$2"
            if [[ -z "$alias_name" ]]; then
                echo "用法: cc-token-monitor price-alias remove <别名>"
                return 1
            fi
            local tmp=$(mktemp)
            jq --arg alias "$alias_name" 'del(.aliases[$alias])' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
            echo -e "${GREEN}已删除别名: $alias_name${NC}"
            ;;
        list|*)
            echo ""
            echo -e "${CYAN}模型别名列表:${NC}"
            echo ""
            local count
            count=$(jq '.aliases // {} | keys | length' "$CONFIG_FILE" 2>/dev/null || echo 0)
            if [[ "$count" -eq 0 ]]; then
                echo "  (暂无别名)"
                echo ""
                echo "添加别名示例:"
                echo "  cc-token-monitor price-alias add kimi-for-coding kimi-k2.5"
            else
                jq -r '.aliases // {} | to_entries[] | "  \(.key)  →  \(.value)"' "$CONFIG_FILE" 2>/dev/null
            fi
            echo ""
            ;;
    esac
}

start_watch() {
    if ! command -v fswatch &>/dev/null; then
        echo -e "${RED}错误: fswatch 未安装，运行: brew install fswatch${NC}"
        return 1
    fi
    echo -e "${GREEN}开始实时监控...${NC}"
    init_process
    fswatch -r -e ".*" -i "\\.jsonl$" --event Created --event Updated "$PROJECTS_DIR" 2>/dev/null | while read -r file; do
        [[ "$file" == *.jsonl ]] || continue
        local count=$(process_file "$file")
        [[ -n "$count" && "$count" -gt 0 ]] && echo -e "[$(date '+%H:%M:%S')] +$count 条记录" && show_today
    done
}

# HUD 相关函数
HUD_PID_FILE="$STATS_DIR/hud.pid"

start_hud() {
    # 检查是否为 macOS
    if [[ "$OSTYPE" != "darwin"* ]]; then
        echo -e "${RED}错误: HUD 悬浮窗仅支持 macOS${NC}"
        return 1
    fi

    # 检查是否已有 HUD 进程在运行（通过 pgrep 检测所有可能的进程）
    local existing_pids=$(pgrep -f "cc-token-monitor-hud" 2>/dev/null)
    if [[ -n "$existing_pids" ]]; then
        local count=$(echo "$existing_pids" | wc -l | tr -d ' ')
        echo -e "${YELLOW}检测到 $count 个 HUD 进程已在运行${NC}"
        echo "$existing_pids" | while read -r pid; do
            echo "  PID: $pid"
        done
        echo "运行 'cc-token-monitor hud-restart' 重启 或 'cc-token-monitor hud-stop' 停止"
        return 0
    fi

    # 清理可能存在的旧 PID 文件
    rm -f "$HUD_PID_FILE"

    # 查找 HUD 可执行文件
    local hud_bin=""
    local script_dir="$(cd "$(dirname "$0")" && pwd)"

    if [[ -f "$script_dir/../hud/.build/release/cc-token-monitor-hud" ]]; then
        # 开发模式
        hud_bin="$script_dir/../hud/.build/release/cc-token-monitor-hud"
    elif [[ -f "$HOME/projects/cc-token-monitor/hud/.build/release/cc-token-monitor-hud" ]]; then
        # 项目目录
        hud_bin="$HOME/projects/cc-token-monitor/hud/.build/release/cc-token-monitor-hud"
    elif [[ -f "/usr/local/bin/cc-token-monitor-hud" ]]; then
        hud_bin="/usr/local/bin/cc-token-monitor-hud"
    elif command -v cc-token-monitor-hud &>/dev/null; then
        hud_bin="$(command -v cc-token-monitor-hud)"
    else
        echo -e "${RED}错误: 未找到 cc-token-monitor-hud${NC}"
        echo "请先构建 HUD:"
        echo "  cd $(dirname "$0")/.. && make hud-build"
        return 1
    fi

    echo -e "${GREEN}启动 HUD 悬浮窗...${NC}"
    nohup "$hud_bin" &>/dev/null &
    local pid=$!
    echo $pid > "$HUD_PID_FILE"

    sleep 1
    if ps -p "$pid" &>/dev/null; then
        echo -e "${GREEN}✓ HUD 已启动 (PID: $pid)${NC}"
        echo "点击菜单栏图标控制显示/隐藏"
        echo "运行 'cc-token-monitor hud-stop' 停止"
    else
        echo -e "${RED}✗ HUD 启动失败${NC}"
        rm -f "$HUD_PID_FILE"
        return 1
    fi
}

stop_hud() {
    local killed=0

    # 首先尝试停止 PID 文件中的进程
    if [[ -f "$HUD_PID_FILE" ]]; then
        local pid=$(cat "$HUD_PID_FILE" 2>/dev/null)
        if [[ -n "$pid" ]] && ps -p "$pid" &>/dev/null; then
            kill "$pid" 2>/dev/null
            sleep 0.5
            # 如果还在运行，强制杀死
            if ps -p "$pid" &>/dev/null; then
                kill -9 "$pid" 2>/dev/null
            fi
            ((killed++))
        fi
        rm -f "$HUD_PID_FILE"
    fi

    # 查找并停止所有其他 HUD 进程
    local pids=$(pgrep -f "cc-token-monitor-hud" 2>/dev/null)
    if [[ -n "$pids" ]]; then
        echo "$pids" | while read -r pid; do
            kill "$pid" 2>/dev/null
            sleep 0.2
            # 强制杀死如果还在运行
            if ps -p "$pid" &>/dev/null; then
                kill -9 "$pid" 2>/dev/null
            fi
            ((killed++))
        done
    fi

    if [[ $killed -gt 0 ]]; then
        echo -e "${GREEN}✓ HUD 已停止 (共 $killed 个进程)${NC}"
    else
        echo -e "${YELLOW}HUD 未运行${NC}"
    fi
}

restart_hud() {
    stop_hud
    sleep 1
    start_hud
}

show_help() {
cat << 'EOF'
用法: cc-token-monitor [命令] [参数]

命令:
    watch                   启动实时监控
    once                    一次性处理所有文件
    rescan                  全量重新统计（清除缓存，重新扫描所有历史数据）
    today                   显示今日统计（按模型）
    date [YYYY-MM-DD]       显示指定日期统计（按模型）
    sessions [YYYY-MM-DD]   显示指定日期会话明细
    project [YYYY-MM-DD]    显示按项目汇总
    summary                 显示历史汇总
    export [YYYY-MM-DD]     导出 CSV 报告
    config                  查看/编辑价格配置
    price <model>           查询指定模型价格
    price-update            从 LiteLLM 拉取最新模型价格
    price-alias [sub]       管理模型别名 (add/list/remove)

快捷别名 (需添加到 ~/.zshrc):
    cctok                   等同于 cc-token-monitor
    cctoday                 显示今日统计
    ccrescan                全量重新统计
    ccsum                   显示历史汇总
    ccsessions/ccsess       显示今日会话明细
    ccproj                  显示按项目汇总
    cchud                   启动悬浮窗 (macOS)
    cchud-stop              停止悬浮窗 (macOS)

Web 界面命令:
    ccweb [端口]            启动 Web 界面 (默认端口 8866)
    ccweb-stop [端口]       停止 Web 界面

macOS 悬浮窗命令 (仅 macOS):
    hud                     启动悬浮窗 (实时监控)
    hud-stop                停止悬浮窗
    hud-restart             重启悬浮窗

配置文件:
    ~/.claude/token-stats/config/prices.json

CSV格式: date,session_id,project,model,input,output,cache_create,cache_read,total,cost
价格: 支持 30+ 模型，详见 config 命令或编辑配置文件
EOF
}

# 检查价格新鲜度（help / price-update / watch 命令时跳过）
case "${1:-}" in
    help|--help|-h|price-update|price-alias|watch) ;;
    *) check_price_freshness ;;
esac

case "${1:-help}" in
    watch) start_watch ;;
    once) init_process; show_today ;;
    rescan) rescan_all ;;
    today) show_today ;;
    date) show_date_models "${2:-$(date +%Y-%m-%d)}" ;;
    sessions) show_sessions "${2:-$(date +%Y-%m-%d)}" ;;
    project) show_by_project "${2:-$(date +%Y-%m-%d)}" ;;
    summary) show_summary ;;
    export) export_csv "${2:-$(date +%Y-%m-%d)}" ;;
    config) show_config ;;
    price) query_price "$2" ;;
    price-update) fetch_litellm_prices ;;
    price-alias) cmd_price_alias "$2" "$3" "$4" ;;
    help|--help|-h) show_help ;;
    *)
        # 检查是否为 hud 相关命令
        case "$1" in
            hud) start_hud ;;
            hud-stop) stop_hud ;;
            hud-restart) restart_hud ;;
            *) echo -e "${RED}未知命令: $1${NC}"; show_help; exit 1 ;;
        esac
        ;;
esac
